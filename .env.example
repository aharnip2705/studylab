# Supabase - https://supabase.com/dashboard adresinden proje oluşturup bu değerleri alın
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# Opsiyonel - AI Koç (Groq)
# GROQ_API_KEY=your_groq_api_key

# Opsiyonel - YouTube API (video thumbnails, oynatma listeleri)
# YOUTUBE_API_KEY=your_youtube_api_key

# Invidious instance - Video stream proxy (YouTube embed kısıtlamalarını aşar)
# Varsayılan: inv.nadeko.net, invidious.nerdvpn.de, yewtu.be (sırayla denenecek)
# Tek instance zorunlu kılmak için:
# NEXT_PUBLIC_INVIDIOUS_INSTANCE=https://inv.nadeko.net

# Opsiyonel - Admin (virgülle ayırın)
# ADMIN_EMAILS=admin@example.com
